{
  "name": "beloved-remote",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Modules": {
        "$className": "Folder",
        "$ignoreUnknownInstances": true,

        "BelovedRemote": {
          "$path": "src/BelovedRemote"
        }
      },

      "_BelovedTester": {
        "$className": "Folder",
        "$path": "src/BelovedTester"
      }
    }
  },
  "globIgnorePaths": ["**/wally.toml"]
}